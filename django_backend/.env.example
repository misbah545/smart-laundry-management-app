# SmartLaundry Environment Configuration
# Copy this file to .env and update values for your environment

# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-change-this-in-production
ENVIRONMENT=production
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
SECURE_SSL_REDIRECT=True
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Database Configuration
DB_ENGINE=django.db.backends.postgresql
DB_NAME=smartlaundry
DB_USER=postgres
DB_PASSWORD=your-secure-password
DB_HOST=localhost
DB_PORT=5432
DB_SSL=False

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379/0

# Celery Configuration
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@smartlaundry.com

# Stripe Configuration
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key

# AWS S3 Configuration (if using S3 for file storage)
USE_S3=False
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=smartlaundry-media
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# API Rate Limiting
API_RATE_LIMIT_ANON=100/hour
API_RATE_LIMIT_USER=1000/hour

# WebSocket Configuration
WEBSOCKET_TIMEOUT=300
WEBSOCKET_MAX_CONNECTIONS=1000

# Geofencing Configuration
GEOFENCE_RADIUS_METERS=100
GEOFENCE_UPDATE_INTERVAL=60

# Analytics Configuration
ANALYTICS_RETENTION_DAYS=90
ANALYTICS_BATCH_SIZE=100

# Push Notifications
EXPO_ACCESS_TOKEN=your-expo-access-token
PUSH_NOTIFICATION_ENABLED=True
PUSH_NOTIFICATION_TIMEOUT=30

# Sentry Error Tracking (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Datadog APM (optional)
DD_API_KEY=
DD_APP_KEY=
DD_SITE=datadoghq.com
DD_AGENT_HOST=localhost
DD_AGENT_PORT=8126
DD_SERVICE_NAME=smartlaundry
DD_PROFILING_ENABLED=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/var/log/smartlaundry/django.log

# Cache Configuration
CACHE_TIMEOUT=300
CACHE_MAX_SIZE=10000

# Session Configuration
SESSION_TIMEOUT=86400
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Security Configuration
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_SECURITY_POLICY_ENABLED=True
X_FRAME_OPTIONS=SAMEORIGIN

# Frontend Configuration
REACT_APP_API_URL=https://api.your-domain.com
REACT_APP_WS_URL=wss://api.your-domain.com/ws
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key

# Development Settings (set to True only in development)
ALLOW_UNSAFE_HEADERS=False
ENABLE_SWAGGER_DOCS=False
ENABLE_DJANGO_ADMIN=True
